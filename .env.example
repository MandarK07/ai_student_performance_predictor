# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------

# [LOCAL DEVELOPMENT]
# Use this for your local PostgreSQL instance (Fast, no latency)
DATABASE_URL=postgresql://postgres:password@localhost:5432/student_performance_db

# [PRODUCTION / CLOUD] 
# (e.g., Neon.tech, Supabase, or Render Managed Postgres)
# Do NOT commit your actual cloud URL to version control.
# Set this variable directly in your Render/Vercel Environment Settings dashboard.
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname?sslmode=require

# Application Settings
APP_ENV=development
DEBUG=True
JWT_SECRET=your-jwt-secret-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=ai-student-performance-predictor

# CORS Settings
# Use a comma-separated list if you need multiple frontend origins.
FRONTEND_URL=http://localhost:5173

# Model Settings
MODEL_PATH=models/random_forest.joblib
PREDICTION_THRESHOLD=0.5

# Default Admin Bootstrap
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@studentai.com
ADMIN_PASSWORD=change-me-in-production
ADMIN_FULL_NAME=System Administrator
ADMIN_SYNC_ON_STARTUP=false

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=data/uploads/

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
